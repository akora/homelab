#!/bin/bash
# Gitea Backup Verification Script
# Performs deep validation: zip integrity, required files, DB import, and git fsck

set -euo pipefail

BACKUP_BASE_DIR="{{ gitea_backup_base_dir }}"
BACKUP_DIR="${BACKUP_BASE_DIR}/daily"
LOG_FILE="${BACKUP_BASE_DIR}/verify.log"
TEMP_DIR=""

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

error() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $1" | tee -a "$LOG_FILE" >&2
}

cleanup() {
    if [ -n "$TEMP_DIR" ] && [ -d "$TEMP_DIR" ]; then
        rm -rf "$TEMP_DIR"
        log "Cleaned up temp directory"
    fi
}
trap cleanup EXIT

# Resolve backup file
if [ "${1:-}" = "--list" ]; then
    ls -lht "${BACKUP_DIR}"/*.zip 2>/dev/null || echo "No backups found"
    exit 0
elif [ "${1:-}" = "--latest" ] || [ -z "${1:-}" ]; then
    backup_file=$(cd "${BACKUP_DIR}" && ls -t gitea-dump-*.zip 2>/dev/null | head -1)
    if [ -z "$backup_file" ]; then
        error "No backup files found in ${BACKUP_DIR}"
        exit 1
    fi
else
    backup_file="$1"
fi

backup_path="${BACKUP_DIR}/${backup_file}"

if [ ! -f "$backup_path" ]; then
    error "Backup file not found: $backup_path"
    exit 1
fi

log "========================================"
log "Verifying backup: $backup_file"
log "========================================"

# 1. Zip integrity test
log "[1/4] Testing zip integrity..."
if unzip -t "$backup_path" > /dev/null 2>&1; then
    log "  ✓ Zip file is not corrupt"
else
    error "  ✗ Zip file is corrupt!"
    exit 1
fi

# 2. Extract to temp dir and check required files
log "[2/4] Extracting and checking required files..."
TEMP_DIR=$(mktemp -d /tmp/gitea-verify-XXXXXX)
unzip -q "$backup_path" -d "$TEMP_DIR"

for required in app.ini gitea-db.sql; do
    found=$(find "$TEMP_DIR" -name "$required" | head -1)
    if [ -n "$found" ]; then
        size=$(du -sh "$found" | cut -f1)
        log "  ✓ Found $required ($size)"
    else
        error "  ✗ Missing $required"
        exit 1
    fi
done

# 3. SQL database validation — import into in-memory SQLite
log "[3/4] Validating database (importing SQL into memory)..."
sql_file=$(find "$TEMP_DIR" -name "gitea-db.sql" | head -1)

python3 - "$sql_file" << 'PYEOF'
import sqlite3, sys, re

sql_file = sys.argv[1]
sql = open(sql_file, 'r').read()

# Strip xorm header comment before executing
sql = re.sub(r'^/\*.*?\*/', '', sql, flags=re.DOTALL).strip()

conn = sqlite3.connect(':memory:')
try:
    conn.executescript(sql)
except Exception as e:
    print(f"ERROR: Failed to import SQL: {e}", file=sys.stderr)
    sys.exit(1)

tables = conn.execute("SELECT COUNT(*) FROM sqlite_master WHERE type='table'").fetchone()[0]
rows = sum(
    conn.execute(f"SELECT COUNT(*) FROM \"{row[0]}\"").fetchone()[0]
    for row in conn.execute("SELECT name FROM sqlite_master WHERE type='table'")
)
conn.close()
print(f"  ✓ Database imported successfully ({tables} tables, {rows} total rows)")
PYEOF

# 4. Git repo validation
log "[4/4] Validating git repositories..."
repos_dir=$(find "$TEMP_DIR" -type d -name "repos" | head -1)
if [ -z "$repos_dir" ]; then
    log "  ⚠ No repositories directory found"
else
    repo_count=0
    fail_count=0
    while IFS= read -r -d '' repo; do
        repo_name=$(realpath --relative-to="$repos_dir" "$repo")
        if git -c safe.directory="*" -C "$repo" fsck > /dev/null 2>&1; then
            repo_count=$((repo_count + 1))
        else
            error "  ✗ Repository failed fsck: $repo_name"
            fail_count=$((fail_count + 1))
        fi
    done < <(find "$repos_dir" -maxdepth 2 -name "*.git" -type d -print0)

    if [ $fail_count -eq 0 ]; then
        log "  ✓ All $repo_count repositories passed git fsck"
    else
        error "  ✗ $fail_count repositories failed validation"
        exit 1
    fi
fi

log "========================================"
log "✓ Backup verification PASSED: $backup_file"
log "========================================"
